{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data-display/**",
              "components/date/**",
              "components/disclosure/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlays/**",
              "components/surfaces/**",
              "components/typography/**",
              "decks/**",
              "ui_kits/console/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color \u2014 use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value \u2014 use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Inter|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Inter, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|multiple|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: children, multiple, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, icon, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|info|success|warning|destructive)$/]",
        "message": "<Alert> variant must be one of 'default' | 'info' | 'success' | 'warning' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertDialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|defaultOpen|onOpenChange|trigger|title|description|cancelText|actionText|onAction|destructive|key|ref|className|style|children)$/]",
        "message": "<AlertDialog> doesn't accept that prop. Declared props: open, defaultOpen, onOpenChange, trigger, title, description, cancelText, actionText, onAction, destructive."
      },
      {
        "selector": "JSXOpeningElement[name.name='AspectRatio'] > JSXAttribute > JSXIdentifier[name!=/^(?:ratio|children|style|key|ref|className|style|children)$/]",
        "message": "<AspectRatio> doesn't accept that prop. Declared props: ratio, children, style."
